{
  "name": "blogcms-admin",
  "version": "1.0.0",
  "description": "BlogCMS Admin Dashboard - Fastify backend with HTMX",
  "type": "module",
  "scripts": {
    "start": "node app.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run watch:css\"",
    "dev:server": "nodemon app.js",
    "build:css": "npx sass scss/admin/main.scss .build/admin.css --no-source-map && npx sass scss/app/main.scss .build/app.css --no-source-map && npx postcss css/index.css -o dist/css/admin.css && npx postcss css/app.css -o dist/css/app.css",
    "watch:css": "chokidar 'scss/**/*.scss' -c 'npm run build:css' --initial",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/migrate.js",
    "db:push": "drizzle-kit push",
    "db:seed": "node scripts/seed.js",
    "db:seed:fresh": "node scripts/seed.js --fresh",
    "db:reset": "npm run db:migrate && npm run db:seed:fresh",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:smoke": "vitest run tests/smoke",
    "check": "node scripts/check.js && vitest run",
    "check:ci": "node scripts/check.js && vitest run tests/unit --exclude '**/forgot-password.flow.test.js'",
    "test:e2e": "playwright test",
    "db:test": "node scripts/cli.js db test",
    "setup:token": "node scripts/cli.js setup-token",
    "simulate:day": "node scripts/cli.js analytics day",
    "simulate:days": "node scripts/cli.js analytics day --days=90 --backdate",
    "media:thumbs": "node scripts/cli.js media thumbnails"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^8.1.1",
    "@fastify/static": "^7.0.4",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.28.1",
    "fastify-html": "^0.3.2",
    "fluent-ffmpeg": "^2.1.3",
    "htmx.org": "^2.0.10",
    "mysql2": "^3.11.3",
    "nodemailer": "^9.0.3",
    "otplib": "^13.4.1",
    "pino": "^9.3.1",
    "pino-pretty": "^11.2.2",
    "preline": "^4.0.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.4",
    "slugify": "^1.6.6",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.3",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/postcss": "^4.1.18",
    "autoprefixer": "^10.4.24",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.21.0",
    "node-cron": "^3.0.3",
    "nodemon": "^3.1.4",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.0",
    "postcss-nesting": "^14.0.0",
    "sass": "^1.77.8",
    "tailwindcss": "^4.1.18",
    "vitest": "^2.0.3"
  },
  "keywords": [
    "blog",
    "cms",
    "fastify",
    "htmx",
    "drizzle",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
