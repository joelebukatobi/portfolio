# Development Environment Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration
DATABASE_URL=mysql://root:password@localhost:3306/blogcms_dev

# Security
JWT_SECRET=dev-jwt-secret-key-change-in-production-min-32-characters
SESSION_SECRET=dev-session-secret-key-change-in-production-min-32-characters

# Email Configuration (for development)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-dev-email@gmail.com
SMTP_PASS=your-app-password

# OAuth Configuration (optional for dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./public/uploads

# Logging
LOG_LEVEL=debug

# Admin Configuration
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
